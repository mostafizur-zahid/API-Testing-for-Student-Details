    {
      "name": "Create Technical Skills",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var skills = [",
              "    \"Java\",",
              "    \"Python\",",
              "    \"C++\",",
              "    \"JavaScript\",",
              "    \"Go\",",
              "    \"Rust\",",
              "    \"PHP\",",
              "    \"TypeScript\",",
              "    \"Kotlin\",",
              "    \"Swift\"",
              "];",
              "",
              "// Random skills",
              "var lang1 = skills[Math.floor(Math.random() * skills.length)];",
              "var lang2 = skills[Math.floor(Math.random() * skills.length)];",
              "pm.environment.set(\"lang1\", lang1);",
              "pm.environment.set(\"lang2\", lang2);",
              "// Random year experience",
              "var exp = Math.floor(Math.random() * 10) + 1;",
              "pm.environment.set(\"yearexp\", exp);",
              "",
              "var date = require('moment')().format('DD-MM-YYYY');",
              "pm.environment.set(\"lastused\", date);",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
