              "})",
              "",
              "pm.test(\"Response file JSON or Not\", function(){",
              "    pm.response.to.be.json;",
              "});",
              "",
              "var responseBody = pm.response.json(); ",
              "console.log(responseBody);",
              "",
              "pm.test(\"Verify current status\", function () {",
              "    pm.expect(responseBody.status).to.eql(\"true\");",
              "});",
              "",
              "pm.test(\"Notify Message Verify\", function(){",
              "    pm.expect(responseBody.msg).to.eql(\"Add  data success\");",
